# Required for Railway deployment
# Copy this file to .env and fill in your actual values

# ============================================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================================

# Database (Railway PostgreSQL - automatically provided)
DATABASE_URL=postgresql+asyncpg://postgres:password@host:port/database

# AI Service
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-frontend-url.railway.app/auth/callback

# URLs (Update after deployment)
FRONTEND_URL=https://your-frontend-url.railway.app
BACKEND_URL=https://your-backend-url.railway.app

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (.env in frontend folder)
# ============================================================================

# API Base URL (Backend Railway URL)
VITE_API_BASE_URL=https://your-backend-url.railway.app
