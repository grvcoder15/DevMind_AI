# DevMind AI — Environment Configuration
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
# RECOMMENDATION: Use Ollama for FREE local LLM
# Provider options: ollama | huggingface | openrouter | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (FREE & Local - RECOMMENDED)
# Install: curl https://ollama.ai/install.sh | sh (Linux/Mac)
# Windows: https://ollama.ai/download/windows
# Pull model: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace (FREE tier available)
# Get API key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-hf-api-key-here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# OpenRouter (FREE models available)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Paid Providers (Optional)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=claude-3-5-sonnet-20241022

# LLM Parameters
TEMPERATURE=0.25
MAX_TOKENS=2048

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL (Replace [YOUR-PASSWORD] and [YOUR-PROJECT-REF] with your Supabase details)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase API credentials (for auth and storage features)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
